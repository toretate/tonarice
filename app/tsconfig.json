{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": [
            "ESNext",
            "DOM"
        ],
        "skipLibCheck": true,
        "noEmit": true,
        "incremental": true,
        "tsBuildInfoFile": "./node_modules/.cache/typescript/vue.tsbuildinfo",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@prompt/*": [
                "src/skills/tool-use/prompts/*"
            ],
            "@tonarice/expression-alignment": [
                "../packages/expression-alignment/src/index.ts"
            ],
            "@tonarice/expression-alignment/adapters/opencv-browser": [
                "../packages/expression-alignment/adapters/opencv-browser.ts"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "src/**/*.vue"
    ]
}
