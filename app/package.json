{
    "name": "desktop-ai-mascot",
    "version": "1.0.0",
    "main": "dist-electron/main.cjs",
    "type": "module",
    "scripts": {
        "dev": "nuxt dev",
        "dev:remote": "nuxt dev --host 0.0.0.0",
        "dev:electron": "node scripts/dev-electron.js",
        "build": "tsup && nuxt build",
        "lint": "biome lint . --diagnostic-level=error",
        "preview": "nuxt preview",
        "preview:remote": "nuxt preview --host 0.0.0.0",
        "test": "vitest run",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:browser:watch": "vitest --config vitest.browser.config.ts",
        "typecheck": "vue-tsc --project tsconfig.json --noEmit",
        "typecheck:electron": "tsc --project tsconfig.electron.json --noEmit",
        "typecheck:all": "npm run typecheck && npm run typecheck:electron",
        "kill": "taskkill /f /im node.exe /im electron.exe",
        "postinstall": "patch-package"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.83",
        "@ai-sdk/openai": "^3.0.73",
        "@formkit/drag-and-drop": "^0.6.1",
        "@imgly/background-removal-node": "^1.4.3",
        "@lmstudio/sdk": "^1.5.0",
        "@primevue/themes": "^4.0.0",
        "@types/js-yaml": "^4.0.9",
        "ai": "^6.0.208",
        "better-sqlite3": "^11.3.0",
        "esbuild": "^0.28.1",
        "express": "^4.19.2",
        "js-yaml": "^4.2.0",
        "pinia": "^2.3.0",
        "pixi.js": "^8.19.0",
        "primeflex": "^4.0.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.0.0",
        "vue": "^3.4.0",
        "vue-draggable-plus": "^0.6.1",
        "ws": "^8.16.0",
        "zod": "^3.25.76",
        "zod-to-json-schema": "^3.25.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@nuxtjs/tailwindcss": "6.14.0",
        "@pinia/nuxt": "^0.9.0",
        "@types/better-sqlite3": "^7.6.13",
        "@vitest/browser-playwright": "4.1.9",
        "@vue/test-utils": "^2.4.11",
        "autoprefixer": "^10.5.0",
        "canvas": "^3.2.3",
        "electron": "^33.2.1",
        "electron-builder": "^24.13.3",
        "happy-dom": "^20.10.2",
        "jsdom": "^29.1.1",
        "nuxt": "3.15.0",
        "patch-package": "^8.0.1",
        "playwright": "1.61.1",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.19",
        "tsup": "^8.0.2",
        "typescript": "^5.4.0",
        "vitest": "^4.1.9",
        "vitest-browser-vue": "2.1.0",
        "vue-tsc": "2.1.10"
    }
}
