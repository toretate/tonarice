<UserControl x:Class="DesktopAiMascot.views.MascotEdit.MascotEditSettingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DesktopAiMascot.views.MascotEdit"
             xmlns:views="clr-namespace:DesktopAiMascot.views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">
    <Grid Margin="5,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="400"/>
        </Grid.RowDefinitions>
        
        <!-- 上部：基本情報 -->
        <StackPanel Grid.Row="0">
            <Label Content="名前" FontWeight="Bold" FontSize="12" Padding="0" />
            <TextBox x:Name="displayNameTextBox" 
                Height="30" 
                FontSize="14"
                VerticalContentAlignment="Center"/>

            <Label Content="プロフィールなど" FontWeight="Bold" FontSize="12" Padding="0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="80"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label x:Name="editPromptButton" 
                    Content="設定ファイル：" 
                    Height="30"
                    Grid.Column="0"
                    />
                <Border BorderBrush="Black" BorderThickness="1" Grid.Column="1">
                    <TextBlock x:Name="mascotConfigTextBox"></TextBlock>
                </Border>
                <Button x:Name="profileEditButton" 
                    Content="エディタ起動" 
                    Height="30"
                    Grid.Column="2"
                    Click="EditPromptButton_Click"
                    />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="80"></ColumnDefinition>
                    <ColumnDefinition Width="100"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label x:Name="generateProfileFromFileButton" 
                    Content="ファイルからプロフィールを生成：" 
                    Height="30"
                    />
                <Border BorderBrush="Black" BorderThickness="1" Grid.Column="1">
                    <TextBlock x:Name="generateProfileFromFileTextField"
                               AllowDrop="True"
                               PreviewDragOver="GenerateProfileFromFileTextField_PreviewDragOver"
                               Drop="GenerateProfileFromFileTextField_Drop"/>
                </Border>
                <Button x:Name="generateProfileFileChooserButton" 
                    Content="生成" 
                    Height="30"
                    Grid.Column="2"
                    Click="GenerateProfileFileChooserButton_Click"
                    />
                <ComboBox x:Name="generateProfileModelComboBox"
                          Width="100"
                          HorizontalAlignment="Left"
                          DisplayMemberPath="Name"
                          SelectedIndex="0"
                          Grid.Column="3"
                          />
            </Grid>

            <GroupBox x:Name="profileGroupBox" Grid.Column="1" Height="200" Margin="5,0,0,0">
                <GroupBox.Header>
                    <Grid>
                        <TextBlock Text="プロフィール" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox.Header>
                <TextBox
                        x:Name="profileTextBlock"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="0" Margin="0"
                        />
            </GroupBox>
        </StackPanel>

        <!-- 下部：タブコントロール（可変サイズ） -->
        <TabControl x:Name="mascotSettingsTabControl" Grid.Row="1" Margin="0,5,0,5">
            <!-- タブアイテムはコードビハインドで追加 -->
            <TabItem Header="角度">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <GroupBox x:Name="angleViewGroupBox" Margin="10">
                        <GroupBox.Header>
                            <Grid>
                                <TextBlock Text="図" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox.Header>
                        <views:AngleViewControl x:Name="angleViewControl" Height="350" VerticalAlignment="Top"/>
                    </GroupBox>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="背景削除">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10">
                        <!-- 背景削除ボタン -->
                        <Button x:Name="removeBackgroundButton" 
                            Content="背景を削除" 
                            Width="100" 
                            Height="30"
                            IsEnabled="False"
                            Click="RemoveBackgroundButton_Click"
                            Margin="0,0,0,10"/>

                        <!-- 背景削除処理コンボボックス -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Label Content="背景削除AI" FontWeight="Bold" FontSize="10" Padding="0,0,0,0" Margin="0,5,10,2"/>
                            <ComboBox x:Name="backgroundRemovalServiceComboBox"
                                      Width="150"
                                      Height="25"
                                      HorizontalAlignment="Left"
                                      DisplayMemberPath="Name"
                                      SelectedIndex="0"/>
                        </StackPanel>

                        <Button x:Name="restoreBackgroundButton" 
                            Content="背景削除前に戻す" 
                            Width="130" 
                            Height="30"
                            IsEnabled="False"
                            Click="RestoreBackgroundButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="画像追加">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10">
                        <Button x:Name="addImageButton" 
                            Content="画像を追加" 
                            Width="100" 
                            Height="30"
                            Margin="0,0,5,0"
                            Click="AddImageButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="表情差分作成" x:Name="emoteGenerationTabItem">
                <local:EmoteGenerationTabPage x:Name="emoteGenerationTabPage"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
