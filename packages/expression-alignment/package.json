{
    "name": "@desktop-ai-mascot/expression-alignment",
    "version": "0.0.0",
    "private": true,
    "description": "マスコット表情スプライト自動位置合わせライブラリ（framework/DOM 非依存・決定論的）",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./src/index.ts",
        "./adapters/canvas-node": "./adapters/canvas-node.ts",
        "./adapters/canvas-browser": "./adapters/canvas-browser.ts",
        "./adapters/opencv-node": "./adapters/opencv-node.ts",
        "./adapters/opencv-browser": "./adapters/opencv-browser.ts"
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "canvas": "^3.2.3",
        "opencv-wasm": "^4.3.0-10",
        "typescript": "^5.4.0",
        "vitest": "^1.4.0"
    },
    "dependencies": {
        "@techstark/opencv-js": "^4.12.0-release.1"
    }
}
