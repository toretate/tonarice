<UserControl x:Class="DesktopAiMascot.views.LmChatAiSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DesktopAiMascot.views"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="300"
             Background="White"
             >
    <StackPanel>
        <Label Content="AI Model" FontSize="11" Padding="0" Margin="0,0,0,2"/>
        <ComboBox x:Name="chatAiModelComboBox" 
                  Height="25"
                  DisplayMemberPath="DisplayName"
                  SelectedValuePath="Id"
                  SelectionChanged="ChatAiModelComboBox_SelectionChanged"/>
    </StackPanel>
</UserControl>
