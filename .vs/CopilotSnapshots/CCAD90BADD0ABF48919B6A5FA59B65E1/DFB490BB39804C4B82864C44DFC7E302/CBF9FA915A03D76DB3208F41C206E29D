<UserControl x:Class="DesktopAiMascot.views.aiservice.LmStudioChatSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DesktopAiMascot.views.aiservice"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300"
             Background="White"
             >
    <StackPanel>
		<Grid Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="50"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="15" />
				<RowDefinition Height="20" />
			</Grid.RowDefinitions>
			<Label Content="Endpoint" FontSize="11" Padding="0" Margin="0,0,0,2" FontWeight="Bold" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"/>
			<TextBox x:Name="endpointTextField"
					 Text="http://127.0.0.1:1234/v1/"
					 Margin="0,0,0,0"
					 TextChanged="EndpointTextField_TextChanged"
					 Grid.Row="1" Grid.Column="0"
					 />
			<Button x:Name="updateButton" Content="更新"
					Grid.Row="1" Grid.Column="1"
					Click="UpdateButton_Click">
			</Button>
		</Grid>

		<Grid Margin="0,0,0,10">
			<Grid.RowDefinitions>
				<RowDefinition Height="15" />
				<RowDefinition Height="20" />
			</Grid.RowDefinitions>

			<Label Content="AI Model" FontSize="11" Padding="0" Margin="0,0,0,2" FontWeight="Bold" Grid.Row="0"/>
			<ComboBox x:Name="chatAiModelComboBox"
					  Grid.Row="1"
					  Height="20"
					  DisplayMemberPath="DisplayName"
					  SelectedValuePath="Id"
					  SelectionChanged="ChatAiModelComboBox_SelectionChanged"
					  d:ItemsSource="{d:SampleData ItemCount=3}"
					  />
		</Grid>

	</StackPanel>
</UserControl>
