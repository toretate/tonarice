<Window x:Class="DesktopAiMascot.views.MascotEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopAiMascot.views"
        mc:Ignorable="d"
        Title="マスコット編集" Height="815" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="454"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー：カバー画像と基本情報 -->
        <GroupBox Header="基本情報" Grid.Row="0" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- カバー画像 -->
                <StackPanel Grid.Column="0" Margin="10">
                    <Border BorderBrush="LightGray" BorderThickness="1" 
                        Width="180" Height="180" Margin="0,0,0,0">
                        <Image x:Name="coverImage" Stretch="Uniform" Height="178" VerticalAlignment="Top"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               RenderOptions.EdgeMode="Aliased"/>
                    </Border>
                    <Label Content="表示名" FontWeight="Bold" FontSize="12" Margin="0,0,0,0" Padding="0" />
                    <TextBox x:Name="displayNameTextBox" 
                             Height="30" 
                             FontSize="14"
                             Margin="0,0,0,0"
                             VerticalContentAlignment="Center"/>
                    <Label Content="システムプロンプト" FontWeight="Bold" FontSize="12" Padding="0" Margin="0,0,0,5"/>
                    <Button x:Name="editPromptButton" 
                            Content="外部エディタで編集" 
                            Height="35"
                            Click="EditPromptButton_Click"
                            Margin="0,0,0,15"/>
                </StackPanel>

                <!-- 基本設定 -->
                <StackPanel Grid.Column="1" Margin="5">

                    <GroupBox x:Name="angleViewGroupBox" Height="412">
                        <GroupBox.Header>
                            <Grid>
                                <TextBlock Text="三面図" VerticalAlignment="Center"/>
                                <ComboBox x:Name="imageModelComboBox"
                                          HorizontalAlignment="Right"
                                          Width="180"
                                          Margin="0,0,10,0"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="NanoBanana"/>
                                    <ComboBoxItem Content="NanaBanana Pro"/>
                                    <ComboBoxItem Content="Qwen3 Image Edit"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox.Header>

                        <Grid Height="388" VerticalAlignment="Top">
                            <!-- 中央: frontImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="frontImage" Stretch="Uniform" Source="/assets/icons/angle_front_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>

                            <!-- 左: leftImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="10,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100"
                                    Cursor="Hand">
                                <Image x:Name="leftImage" 
                                       Stretch="Uniform" 
                                       MouseLeftButtonDown="LeftImage_Click" Source="/assets/icons/angle_left_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>

                            <!-- 右: rightImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="230,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="96"
                                    Cursor="Hand">
                                <Image x:Name="rightImage" 
                                       Stretch="Uniform" 
                                       MouseLeftButtonDown="RightImage_Click" Source="/assets/icons/angle_right_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>

                            <!-- 上: aboveImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,10,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100"
                                    Cursor="Hand">
                                <Image x:Name="aboveImage" 
                                       Stretch="Uniform" 
                                       MouseLeftButtonDown="AboveImage_Click" Source="/assets/icons/angle_above_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>

                            <!-- 下: belowImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,230,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100"
                                    Cursor="Hand">
                                <Image x:Name="belowImage" 
                                       Stretch="Uniform" 
                                       MouseLeftButtonDown="BelowImage_Click" Source="/assets/icons/angle_bottom_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>

                            <!-- 背面: behindImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="340,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100"
                                    Cursor="Hand">
                                <Image x:Name="behindImage" 
                                       Stretch="Uniform" 
                                       MouseLeftButtonDown="BehindImage_Click" Source="/assets/icons/angle_behind_sample.png"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"/>
                            </Border>
                            <Label Content="LEFT" HorizontalAlignment="Left" Height="13" Margin="49,224,0,0" VerticalAlignment="Top" Width="22" FontSize="10" Padding="0"/>
                            <Label Content="TOP" HorizontalAlignment="Left" Height="13" Margin="98,56,0,0" VerticalAlignment="Top" Width="22" FontSize="10" Padding="0" RenderTransformOrigin="0.5,0.5">
                                <Label.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="90"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Label.RenderTransform>
                            </Label>
                            <Label Content="RIGHT" HorizontalAlignment="Left" Height="12" Margin="263,225,0,0" VerticalAlignment="Top" Width="30" FontSize="10" Padding="0"/>
                            <Label Content="BEHIND" HorizontalAlignment="Left" Height="12" Margin="372,226,0,0" VerticalAlignment="Top" Width="36" FontSize="10" Padding="0"/>
                            <Label Content="BOTTOM
                                   " HorizontalAlignment="Left" Height="13" Margin="88,276,0,0" VerticalAlignment="Top" Width="42" FontSize="10" Padding="0" RenderTransformOrigin="0.5,0.5">
                                <Label.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="90"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Label.RenderTransform>
                            </Label>
                        </Grid>
                    </GroupBox>

                    <Label Content="画像生成" FontWeight="Bold" FontSize="12" Padding="0" Margin="0,0,0,5"/>
                    <Button x:Name="generateViewsButton" 
                            Content="キャラクター視点画像を生成" 
                            Height="35"
                            Click="GenerateViewsButton_Click"
                            ToolTip="上下左右背面、左前、右前から見た画像を生成"/>

                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 画像一覧 -->
        <GroupBox Header="画像一覧" Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ツールバー -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="addImageButton" 
                            Content="画像を追加" 
                            Width="100" 
                            Height="30"
                            Margin="0,0,5,0"
                            Click="AddImageButton_Click"/>
                    <Button x:Name="removeBackgroundButton" 
                            Content="背景を削除" 
                            Width="100" 
                            Height="30"
                            Margin="0,0,5,0"
                            IsEnabled="False"
                            Click="RemoveBackgroundButton_Click"/>
                    <Button x:Name="restoreBackgroundButton" 
                            Content="背景削除前に戻す" 
                            Width="130" 
                            Height="30"
                            Margin="0,0,5,0"
                            IsEnabled="False"
                            Click="RestoreBackgroundButton_Click"/>
                    <Button x:Name="generateEmotesButton" 
                            Content="表情差分作成" 
                            Width="120" 
                            Height="30"
                            IsEnabled="False"
                            Click="GenerateEmotesButton_Click"/>
                </StackPanel>

                <!-- 画像アルバム表示 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="mascotImageListView" 
                              SelectionMode="Single"
                              SelectionChanged="ImageListView_SelectionChanged" d:ItemsSource="{d:SampleData ItemCount=5}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="itemBorder"
                                        BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Margin="5" 
                                        Padding="5"
                                        Width="140" 
                                        Height="160">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Image Grid.Row="0"
                                               Source="{Binding ImageSource}" 
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               RenderOptions.EdgeMode="Aliased"/>
