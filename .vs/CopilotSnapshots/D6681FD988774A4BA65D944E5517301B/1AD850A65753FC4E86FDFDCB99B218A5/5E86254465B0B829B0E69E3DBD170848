using System;
using System.IO;
using System.Diagnostics;
using DesktopAiMascot.mascots;

namespace DesktopAiMascotTest
{
    class MascotDebugTest
    {
        static void Main()
        {
            Console.WriteLine("=== マスコット設定デバッグ ===");
            
            var mascotName = "misogi";
            var baseDir = AppDomain.CurrentDomain.BaseDirectory;
            var configPath = Path.Combine(baseDir, "assets", "mascots", mascotName, "config.yaml");
            
            Console.WriteLine($"現在のディレクトリ: {baseDir}");
            Console.WriteLine($"config.yaml パス: {configPath}");
            Console.WriteLine($"ファイル存在: {File.Exists(configPath)}");
            
            if (!File.Exists(configPath))
            {
                Console.WriteLine("ERROR: config.yaml が見つかりません");
                return;
            }
            
            // YAML を読み込む
            var yaml = File.ReadAllText(configPath);
            Console.WriteLine($"\nYAML ファイル長: {yaml.Length} 文字");
            Console.WriteLine($"最初の500文字:\n{yaml.Substring(0, Math.Min(500, yaml.Length))}");
            
            // YAML を解析
            Console.WriteLine("\n=== YAML 解析開始 ===");
            var (name, prompt, config) = MascotConfigIO.ParseFromYaml(yaml, mascotName);
            
            Console.WriteLine($"解析後のマスコット名: {name}");
            Console.WriteLine($"解析後のプロンプト長: {prompt?.Length ?? 0}");
            Console.WriteLine($"プロンプトが空か: {string.IsNullOrEmpty(prompt)}");
            
            if (!string.IsNullOrEmpty(prompt))
            {
                Console.WriteLine($"\nプロンプト (最初の300文字):\n{prompt.Substring(0, Math.Min(300, prompt.Length))}");
            }
            
            // Config 解析
            Console.WriteLine($"\n=== Config 解析 ===");
            Console.WriteLine($"SystemPrompt is null: {config?.SystemPrompt == null}");
            if (config?.SystemPrompt != null)
            {
                Console.WriteLine($"Profile.Name: {config.SystemPrompt.Profile?.Name}");
                Console.WriteLine($"Personality.Count: {config.SystemPrompt.Personality?.Count ?? -1}");
                Console.WriteLine($"Voice.Count: {config.Voice?.Count ?? -1}");
            }
            
            // MascotManager でロード
            Console.WriteLine($"\n=== MascotManager でロード ===");
            var manager = new MascotManager();
            manager.Load();
            
            var model = manager.GetMascotByName(mascotName);
            if (model == null)
            {
                Console.WriteLine($"ERROR: マスコット '{mascotName}' がロードされていません");
                Console.WriteLine($"ロードされたマスコット: {string.Join(", ", manager.MascotModels.Keys)}");
                return;
            }
            
            Console.WriteLine($"マスコット '{mascotName}' がロードされました");
            Console.WriteLine($"Model.Prompt 長: {model.Prompt?.Length ?? 0}");
            Console.WriteLine($"Model.Prompt が空か: {string.IsNullOrEmpty(model.Prompt)}");
            
            if (!string.IsNullOrEmpty(model.Prompt))
            {
                Console.WriteLine($"\nModel.Prompt (最初の300文字):\n{model.Prompt.Substring(0, Math.Min(300, model.Prompt.Length))}");
            }
        }
    }
}
