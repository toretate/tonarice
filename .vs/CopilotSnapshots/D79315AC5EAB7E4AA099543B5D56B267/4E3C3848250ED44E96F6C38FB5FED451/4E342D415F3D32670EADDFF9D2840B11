using System;
using System.Diagnostics;
using System.IO;
using System.Text;
using System.Text.RegularExpressions;
using System.Threading.Tasks;
using MeCab;

namespace DesktopAiMascot.skills
{
    /// <summary>
    /// MeCabを使用して英単語やカタカナの読み仮名を高速に取得するスキル
    /// </summary>
    public class MeCabReadingSkill : IDisposable
    {
        private MeCabTagger? _tagger;
        private bool _disposed = false;
        private static readonly Regex EnglishWordRegex = new Regex("[A-Za-z]+", RegexOptions.Compiled);

        /// <summary>
        /// MeCabを初期化します
        /// </summary>
        /// <param name="dicDir">辞書ディレクトリのパス（省略時はデフォルト辞書を使用）</param>
        public void Initialize(string? dicDir = null)
        {
            try
            {
                if (!string.IsNullOrEmpty(dicDir) && Directory.Exists(dicDir))
                {
                    // NEologd辞書などのカスタム辞書を使用
                    _tagger = MeCabTagger.Create($"-d \"{dicDir}\"");
                    Debug.WriteLine($"[MeCabReadingSkill] カスタム辞書を使用: {dicDir}");
                }
                else
                {
                    // デフォルト辞書を使用
                    _tagger = MeCabTagger.Create();
                    Debug.WriteLine("[MeCabReadingSkill] デフォルト辞書を使用");
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[MeCabReadingSkill] 初期化エラー: {ex.Message}");
                _tagger = null;
            }
        }

        /// <summary>
        /// テキスト内の英単語を読み仮名に変換します
        /// </summary>
        public Task<string> ConvertToReadingAsync(string text)
        {
            if (string.IsNullOrEmpty(text))
            {
                return Task.FromResult(text);
            }

            if (_tagger == null)
            {
                Debug.WriteLine("[MeCabReadingSkill] MeCabが初期化されていません");
                return Task.FromResult(text);
            }

            // 英単語が含まれていない場合はそのまま返す
            if (!EnglishWordRegex.IsMatch(text))
            {
                return Task.FromResult(text);
            }

            try
            {
                var result = new StringBuilder();
                var nodes = _tagger.ParseToNodes(text);

                foreach (var node in nodes)
                {
                    if (node.CharType == 0) // BOS/EOS
                        continue;

                    // MeCabの出力フォーマット: 品詞,品詞細分類1,品詞細分類2,品詞細分類3,活用型,活用形,原形,読み,発音
                    var features = node.Feature.Split(',');

                    // 読み（8番目のフィールド）が存在する場合はそれを使用
                    if (features.Length >= 8 && !string.IsNullOrEmpty(features[7]) && features[7] != "*")
                    {
                        result.Append(features[7]);
                    }
                    else
                    {
                        // 読みが取得できない場合は元の表層形を使用
                        result.Append(node.Surface);
                    }
                }

                return Task.FromResult(result.ToString());
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[MeCabReadingSkill] 変換エラー: {ex.Message}");
                return Task.FromResult(text);
            }
        }

        /// <summary>
        /// 単語の読みを取得します
        /// </summary>
        public string GetWordReading(string word)
        {
            if (string.IsNullOrEmpty(word) || _tagger == null)
            {
                return word;
            }

            try
            {
                var nodes = _tagger.ParseToNodes(word);
                foreach (var node in nodes)
                {
                    if (node.CharType == 0) continue;

                    var features = node.Feature.Split(',');
                    if (features.Length >= 8 && !string.IsNullOrEmpty(features[7]) && features[7] != "*")
                    {
                        return features[7];
                    }
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[MeCabReadingSkill] 単語読み取得エラー: {ex.Message}");
            }

            return word;
        }

        public void Dispose()
        {
            if (!_disposed)
            {
                _tagger?.Dispose();
                _tagger = null;
                _disposed = true;
            }
        }
    }
}
