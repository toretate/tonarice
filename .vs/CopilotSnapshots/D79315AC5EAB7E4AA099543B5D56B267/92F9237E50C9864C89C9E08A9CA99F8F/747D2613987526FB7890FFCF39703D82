<UserControl x:Class="DesktopAiMascot.views.VoiceAiPropertyPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DesktopAiMascot.views"
mc:Ignorable="d" 
d:DesignHeight="500" d:DesignWidth="480"
Loaded="VoiceAiPropertyPage_Loaded" Background="White">
    <GroupBox Header="Voice AI" Padding="10">
        <StackPanel>
            <Label Content="Voice AIサービス" FontSize="11" Padding="0" Margin="0,0,0,2"/>
            <ComboBox x:Name="voiceAiComboBox" 
                      Height="25"
                      Margin="0,0,0,10"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectionChanged="VoiceAiComboBox_SelectionChanged"/>

            <Label Content="URL" FontSize="11" Padding="0" Margin="0,0,0,2"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="voiceAiUrlTextField" 
                         Grid.Column="0"
                         Height="25"
                         Margin="0,0,5,0"/>
                <Button x:Name="voiceAiRefreshButton" 
                        Grid.Column="1"
                        Content="更新"
                        Width="60"
                        Height="25"
                        Click="VoiceAiRefreshButton_Click"/>
            </Grid>

            <!-- MeCab辞書管理 -->
            <GroupBox Header="読み仮名変換辞書 (MeCab)" 
                      Padding="10" 
                      Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="辞書の状態:" FontSize="11" Padding="0" Margin="0,0,5,0"/>
                        <Label x:Name="mecabDictionaryStatusLabel" 
                               Content="確認中..." 
                               FontSize="11" 
                               Padding="0" 
                               Foreground="Gray"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" 
                               FontSize="10" 
                               Foreground="Gray" 
                               Margin="0,0,0,10">
                        MeCab辞書を使用すると、英単語の読み仮名変換が高速化されます（約50倍）。
                    </TextBlock>

                    <Button x:Name="downloadDictionaryButton" 
                            Content="辞書をダウンロード" 
                            Height="30"
                            Margin="0,0,0,5"
                            Click="DownloadDictionaryButton_Click"/>

                    <!-- 現在のステップ表示 -->
                    <TextBlock x:Name="dictionaryDownloadStepText" 
                               FontSize="10" 
                               FontWeight="Bold"
                               Foreground="DarkBlue"
                               Margin="0,0,0,2"
                               Visibility="Collapsed"/>

                    <ProgressBar x:Name="dictionaryDownloadProgressBar" 
                                 Height="20" 
                                 Margin="0,0,0,5"
                                 Visibility="Collapsed"/>

                    <!-- 詳細情報表示 -->
                    <TextBlock x:Name="dictionaryDownloadStatusText" 
                               FontSize="10" 
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <TextBlock x:Name="dictionaryDownloadDetailsText" 
                               FontSize="9" 
                               Foreground="DarkGray"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </GroupBox>

            <!-- StyleBertVits2専用設定 -->
            <GroupBox x:Name="styleBertVits2SettingsGroup" 
                      Header="StyleBertVits2 設定" 
                      Padding="10" 
                      Margin="0,0,0,10"
                      Visibility="Collapsed">
                <StackPanel>
                    <!-- サーバー状態表示 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="サーバー状態:" FontSize="11" Padding="0" Margin="0,0,5,0"/>
                        <Label x:Name="styleBertVits2ServerStatusLabel" 
                               Content="確認中..." 
                               FontSize="11" 
                               Padding="0" 
                               Foreground="Gray"/>
                    </StackPanel>
                    
                    <Label Content="AI Model" FontSize="11" Padding="0" Margin="0,0,0,2"/>
                    <ComboBox x:Name="voiceAiModelComboBox" 
                              Height="25"
                              Margin="0,0,0,10"/>

                    <Label Content="Speaker" FontSize="11" Padding="0" Margin="0,0,0,2"/>
                    <ComboBox x:Name="voiceAiSpeakerComboBox" 
                              Height="25"
                              Margin="0,0,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- VoiceVox専用設定 -->
            <GroupBox x:Name="voiceVoxSettingsGroup" 
                      Header="VoiceVox 設定" 
                      Padding="10" 
                      Margin="0,0,0,10"
                      Visibility="Collapsed">
                <StackPanel>
                    <!-- サーバー状態表示 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="サーバー状態:" FontSize="11" Padding="0" Margin="0,0,5,0"/>
                        <Label x:Name="voiceVoxServerStatusLabel" 
                               Content="確認中..." 
                               FontSize="11" 
                               Padding="0" 
                               Foreground="Gray"/>
                    </StackPanel>
                    
                    <Label Content="Speaker (キャラクター)" FontSize="11" Padding="0" Margin="0,0,0,2"/>
                    <ComboBox x:Name="voiceVoxSpeakerComboBox" 
                              Height="25"
                              Margin="0,0,0,10"
                              SelectionChanged="VoiceVoxSpeakerComboBox_SelectionChanged"/>

                    <Label Content="Style (スタイル)" FontSize="11" Padding="0" Margin="0,0,0,2"/>
                    <ComboBox x:Name="voiceVoxStyleComboBox" 
                              Height="25"
                              Margin="0,0,0,0"
                              SelectionChanged="VoiceVoxStyleComboBox_SelectionChanged"/>
                </StackPanel>
            </GroupBox>

            <Button x:Name="saveVoiceToMascotButton" 
                    Content="マスコットにVoiceを設定"
                    Height="30"
                    Click="SaveVoiceToMascotButton_Click"/>
        </StackPanel>
    </GroupBox>
</UserControl>
