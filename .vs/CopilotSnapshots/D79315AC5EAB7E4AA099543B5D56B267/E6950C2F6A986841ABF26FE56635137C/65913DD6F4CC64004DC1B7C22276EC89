using System.Threading.Tasks;
using DesktopAiMascot.skills;
using Xunit;

namespace DesktopAiMascotTest.skills
{
    public class BilingualKanaDictionarySkillTests
    {
        [Fact]
        public async Task ConvertToReadingAsync_空文字列_空文字列を返す()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            skill.Initialize();

            // Act
            var result = await skill.ConvertToReadingAsync("");

            // Assert
            Assert.Equal("", result);
        }

        [Fact]
        public async Task ConvertToReadingAsync_英単語なし_元の文字列を返す()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            skill.Initialize();

            // Act
            var result = await skill.ConvertToReadingAsync("こんにちは");

            // Assert
            Assert.Equal("こんにちは", result);
        }

        [Fact]
        public async Task ConvertToReadingAsync_英単語あり_読み仮名に変換される()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            skill.Initialize();

            // Act
            var result = await skill.ConvertToReadingAsync("私はappleが好きです");

            // Assert
            // MeCabが利用できる場合は読み仮名が取得される
            // 利用できない場合は元の文字列が返される
            Assert.NotNull(result);
            Assert.NotEmpty(result);
        }

        [Fact]
        public void GetWordReading_単語の読みを取得()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            skill.Initialize();

            // Act
            var result = skill.GetWordReading("東京");

            // Assert
            Assert.NotNull(result);
            Assert.NotEmpty(result);
        }

        [Fact]
        public void GetWordReading_空文字列_空文字列を返す()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            skill.Initialize();

            // Act
            var result = skill.GetWordReading("");

            // Assert
            Assert.Equal("", result);
        }

        [Fact]
        public async Task ConvertToReadingAsync_Should_Convert_English_Words()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            var input = "Hello world, this is a test app.";

            // Act
            var result = await skill.ConvertToReadingAsync(input);

            // Assert
            Assert.Contains("ハロー", result);
            Assert.Contains("ワールド", result);
            Assert.Contains("テスト", result);
            Assert.Contains("アプリ", result);
        }

        [Fact]
        public async Task ConvertToReadingAsync_Should_Handle_Japanese_Text()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            var input = "こんにちは world";

            // Act
            var result = await skill.ConvertToReadingAsync(input);

            // Assert
            Assert.Contains("こんにちは", result);
            Assert.Contains("ワールド", result);
        }

        [Fact]
        public async Task ConvertToReadingAsync_Should_Handle_Mixed_Case()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();
            var input = "HELLO Hello hello";

            // Act
            var result = await skill.ConvertToReadingAsync(input);

            // Assert
            // 大文字小文字を区別せず変換
            Assert.DoesNotContain("HELLO", result);
            Assert.Contains("ハロー", result);
        }

        [Fact]
        public void GetWordReading_Should_Return_Reading()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();

            // Act
            var result = skill.GetWordReading("hello");

            // Assert
            Assert.Equal("ハロー", result);
        }

        [Fact]
        public void AddWord_And_SaveDictionary_Should_Work()
        {
            // Arrange
            var skill = new BilingualKanaDictionarySkill();

            // Act
            skill.AddWord("test123", "テストワンツースリー");
            var result = skill.GetWordReading("test123");

            // Assert
            Assert.Equal("テストワンツースリー", result);
        }
    }
}
