using System;
using System.IO;
using System.Text.Json;
using System.Collections.Generic;
using System.Net.Http;
using System.IO.Compression;

namespace MozcDictionaryBuilder
{
    class Program
    {
        static void Main(string[] args)
        {
            string mozcDictDir = "dictionary_oss";
            string outputPath = args.Length > 0 ? args[0] : "bilingual_kana_dictionary.json";

            // 辞書フォルダがなければダウンロード
            if (!Directory.Exists(mozcDictDir))
            {
                Console.WriteLine("mozc辞書データが見つかりません。ダウンロードします...");
                DownloadAndExtractMozcDictionary(mozcDictDir);
            }

            var dictionary = new List<DictionaryEntry>();
            // 複数CSVファイルを処理
            foreach (var csvFile in Directory.GetFiles(mozcDictDir, "*.csv"))
            {
                foreach (var line in File.ReadLines(csvFile))
                {
                    var parts = line.Split(',');
                    if (parts.Length < 2) continue;
                    string word = parts[0];
                    string reading = parts[1];
                    if (IsEnglishWord(word))
                    {
                        dictionary.Add(new DictionaryEntry { English = word, Kana = reading });
                    }
                }
            }

            var json = JsonSerializer.Serialize(dictionary, new JsonSerializerOptions { WriteIndented = true });
            File.WriteAllText(outputPath, json);
            Console.WriteLine($"辞書を出力しました: {outputPath}");
        }

        static void DownloadAndExtractMozcDictionary(string targetDir)
        {
            // mozcリポジトリのzipをダウンロード
            string zipUrl = "https://github.com/google/mozc/archive/refs/heads/master.zip";
            string zipPath = "mozc_master.zip";
            using (var client = new HttpClient())
            {
                var bytes = client.GetByteArrayAsync(zipUrl).Result;
                File.WriteAllBytes(zipPath, bytes);
            }
            // zip展開
            ZipFile.ExtractToDirectory(zipPath, "mozc_master");
            // 辞書フォルダをコピー
            string srcDict = Path.Combine("mozc_master", "mozc-master", "src", "data", "dictionary_oss");
            DirectoryCopy(srcDict, targetDir, true);
            // 後片付け
            File.Delete(zipPath);
            Directory.Delete("mozc_master", true);
        }

        static void DirectoryCopy(string sourceDir, string destDir, bool copySubDirs)
        {
            DirectoryInfo dir = new DirectoryInfo(sourceDir);
            DirectoryInfo[] dirs = dir.GetDirectories();
            if (!Directory.Exists(destDir))
            {
                Directory.CreateDirectory(destDir);
            }
            foreach (FileInfo file in dir.GetFiles())
            {
                string tempPath = Path.Combine(destDir, file.Name);
                file.CopyTo(tempPath, true);
            }
            if (copySubDirs)
            {
                foreach (DirectoryInfo subdir in dirs)
                {
                    string tempPath = Path.Combine(destDir, subdir.Name);
                    DirectoryCopy(subdir.FullName, tempPath, copySubDirs);
                }
            }
        }

        static bool IsEnglishWord(string word)
        {
            foreach (char c in word)
            {
                if (!(char.IsLetter(c) && c <= 127)) return false;
            }
            return true;
        }

        class DictionaryEntry
        {
            public string English { get; set; }
            public string Kana { get; set; }
        }
    }
}
