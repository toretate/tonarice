<Window x:Class="DesktopAiMascot.views.MascotEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopAiMascot.views"
        mc:Ignorable="d"
        Title="マスコット編集" Height="707" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="454"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー：カバー画像と基本情報 -->
        <GroupBox Header="基本情報" Grid.Row="0" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- カバー画像 -->
                <StackPanel Grid.Column="0" Margin="10">
                    <Border BorderBrush="LightGray" BorderThickness="1" 
                        Width="180" Height="180" Margin="0,0,0,0">
                        <Image x:Name="coverImage" Stretch="Uniform" Height="178" VerticalAlignment="Top" Margin="1,-93,-1,0"/>
                    </Border>
                    <Label Content="表示名" FontWeight="Bold" FontSize="12" Margin="0,0,0,0" Padding="0" />
                    <TextBox x:Name="displayNameTextBox" 
                             Height="30" 
                             FontSize="14"
                             Margin="0,0,0,0"
                             VerticalContentAlignment="Center"/>
                    <Label Content="システムプロンプト" FontWeight="Bold" FontSize="12" Padding="0" Margin="0,0,0,5"/>
                    <Button x:Name="editPromptButton" 
                            Content="外部エディタで編集" 
                            Height="35"
                            Click="EditPromptButton_Click"
                            Margin="0,0,0,15"/>
                </StackPanel>

                <!-- 基本設定 -->
                <StackPanel Grid.Column="1" Margin="5">

                    <GroupBox Height="360" Header="三面図">
                        <Grid Height="340" VerticalAlignment="Top">
                            <!-- 中央: frontImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="frontImage" Stretch="Uniform"/>
                            </Border>

                            <!-- 左: leftImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="10,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="leftImage" Stretch="Uniform"/>
                            </Border>

                            <!-- 右: rightImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="230,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="rightImage" Stretch="Uniform"/>
                            </Border>

                            <!-- 上: aboveImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,10,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="aboveImage" Stretch="Uniform"/>
                            </Border>

                            <!-- 下: belowImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="120,230,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="belowImage" Stretch="Uniform"/>
                            </Border>

                            <!-- 背面: behindImage -->
                            <Border BorderBrush="DodgerBlue" 
                                    BorderThickness="2" 
                                    HorizontalAlignment="Left" 
                                    Height="100" 
                                    Margin="340,120,0,0" 
                                    VerticalAlignment="Top" 
                                    Width="100">
                                <Image x:Name="behindImage" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </GroupBox>

                    <Label Content="画像生成" FontWeight="Bold" FontSize="12" Padding="0" Margin="0,0,0,5"/>
                    <Button x:Name="generateViewsButton" 
                            Content="キャラクター視点画像を生成" 
                            Height="35"
                            Click="GenerateViewsButton_Click"
                            ToolTip="上下左右背面、左前、右前から見た画像を生成"/>

                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 画像一覧 -->
        <GroupBox Header="画像一覧" Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ツールバー -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="addImageButton" 
                            Content="画像を追加" 
                            Width="100" 
                            Height="30"
                            Margin="0,0,5,0"
                            Click="AddImageButton_Click"/>
                    <Button x:Name="removeBackgroundButton" 
                            Content="背景を削除" 
                            Width="100" 
                            Height="30"
                            Margin="0,0,5,0"
                            IsEnabled="False"
                            Click="RemoveBackgroundButton_Click"/>
                    <Button x:Name="generateEmotesButton" 
                            Content="表情差分作成" 
                            Width="120" 
                            Height="30"
                            IsEnabled="False"
                            Click="GenerateEmotesButton_Click"/>
                </StackPanel>

                <!-- 画像アルバム表示 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="mascotImageListView" 
                              SelectionMode="Single"
                              SelectionChanged="ImageListView_SelectionChanged">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="itemBorder"
                                        BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Margin="5" 
                                        Padding="5"
                                        Width="140" 
                                        Height="160">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Image Grid.Row="0"
                                               Source="{Binding ImageSource}" 
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding FileName}" 
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontSize="10"
                                                   Margin="0,5,0,0"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                        <Setter TargetName="itemBorder" Property="BorderBrush" Value="DodgerBlue"/>
                                        <Setter TargetName="itemBorder" Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </GroupBox>

        <!-- フッター：アクションボタン -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Width="210">
            <Button x:Name="saveButton" 
                    Content="保存" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button x:Name="cancelButton" 
                    Content="キャンセル" 
                    Width="100" 
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
