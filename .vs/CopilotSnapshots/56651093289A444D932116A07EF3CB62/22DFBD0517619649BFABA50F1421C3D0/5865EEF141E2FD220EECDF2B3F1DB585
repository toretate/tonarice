using System;
using System.Collections.Generic;
using System.Threading.Tasks;
using DesktopAiMascot.aiservice.voice;
using Xunit;

namespace DesktopAiMascotTest.aiservice.voice
{
    public class AiVoiceServiceBaseTests
    {
        private class TestVoiceService : AiVoiceServiceBase
        {
            public override string Name => "Test";
            public override string EndPoint => "http://localhost";

            public override Task<byte[]> SynthesizeAsync(string text)
            {
                return Task.FromResult(Array.Empty<byte>());
            }

            public override async IAsyncEnumerable<byte[]> SynthesizeStreamAsync(string text)
            {
                yield break;
            }

            public string ConvertEnglishWordsToReadingForTest(string text)
            {
                return ConvertEnglishWordsToReading(text);
            }
        }

        [Fact]
        public void ConvertEnglishWordsToReading_英単語をカタカナ読みへ変換する()
        {
            var service = new TestVoiceService();

            var result = service.ConvertEnglishWordsToReadingForTest("今日はAIとUSBを使う");

            Assert.Equal("今日はエーアイとユーエスビーを使う", result);
        }

        [Fact]
        public void ConvertEnglishWordsToReading_英字の連続をスペル読みへ変換する()
        {
            var service = new TestVoiceService();

            var result = service.ConvertEnglishWordsToReadingForTest("Hello World");

            Assert.Equal("エイチイーエルエルオー ダブリューオーアールエルディー", result);
        }
    }
}
