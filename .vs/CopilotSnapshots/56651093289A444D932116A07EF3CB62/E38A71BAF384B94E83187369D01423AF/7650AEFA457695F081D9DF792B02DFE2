using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Text;
using System.Text.Json;
using System.Text.RegularExpressions;
using System.Threading.Tasks;
using DesktopAiMascot.aiservice;

namespace DesktopAiMascot.aiservice.voice
{
    internal static class EnglishReadingConverter
    {
        private static readonly Regex EnglishWordRegex = new Regex("[A-Za-z]+", RegexOptions.Compiled);
        private static readonly Regex EmotionTagRegex = new Regex(@"^\s*\[emotion:\s*[^\]]+\]\s*", RegexOptions.IgnoreCase | RegexOptions.Compiled);
        private static readonly object DictionaryLock = new object();
        private static Dictionary<string, string>? _dictionaryCache;

        private static readonly Dictionary<char, string> AlphabetReadings = new Dictionary<char, string>
        {
            { 'A', "エー" },
            { 'B', "ビー" },
            { 'C', "シー" },
            { 'D', "ディー" },
            { 'E', "イー" },
            { 'F', "エフ" },
            { 'G', "ジー" },
            { 'H', "エイチ" },
            { 'I', "アイ" },
            { 'J', "ジェイ" },
            { 'K', "ケー" },
            { 'L', "エル" },
            { 'M', "エム" },
            { 'N', "エヌ" },
            { 'O', "オー" },
            { 'P', "ピー" },
            { 'Q', "キュー" },
            { 'R', "アール" },
            { 'S', "エス" },
            { 'T', "ティー" },
            { 'U', "ユー" },
            { 'V', "ヴィー" },
            { 'W', "ダブリュー" },
            { 'X', "エックス" },
            { 'Y', "ワイ" },
            { 'Z', "ゼット" }
        };

        private static readonly Dictionary<string, string> DefaultDictionary = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            { "store", "ストア" },
            { "app", "アプリ" },
            { "apps", "アプリ" },
            { "game", "ゲーム" },
            { "games", "ゲーム" },
            { "service", "サービス" },
            { "services", "サービス" },
            { "user", "ユーザー" },
            { "users", "ユーザー" },
            { "desktop", "デスクトップ" },
            { "web", "ウェブ" },
            { "site", "サイト" },
            { "login", "ログイン" },
            { "logout", "ログアウト" },
            { "api", "エーピーアイ" },
            { "tts", "ティーティーエス" },
            { "voice", "ボイス" }
        };

        public static async Task<string> ConvertAsync(string text)
        {
            if (string.IsNullOrEmpty(text))
            {
                return text;
            }

            var dictionary = GetDictionary();
            var convertedText = EnglishWordRegex.Replace(text, match =>
            {
                if (dictionary.TryGetValue(match.Value, out var reading))
                {
                    return reading;
                }

                return match.Value;
            });

            if (!EnglishWordRegex.IsMatch(convertedText))
            {
                return convertedText;
            }

            if (SystemConfig.Instance.UseLlmForEnglishReading)
            {
                var llmResult = await ConvertWithLlmAsync(convertedText);
                if (!string.IsNullOrWhiteSpace(llmResult))
                {
                    return ReplaceRemainingEnglishWords(llmResult);
                }
            }

            return ReplaceRemainingEnglishWords(convertedText);
        }

        private static Dictionary<string, string> GetDictionary()
        {
            if (_dictionaryCache != null)
            {
                return _dictionaryCache;
            }

            lock (DictionaryLock)
            {
                if (_dictionaryCache != null)
                {
                    return _dictionaryCache;
                }

                _dictionaryCache = LoadDictionary();
                return _dictionaryCache;
            }
        }

        private static Dictionary<string, string> LoadDictionary()
        {
            var dictionary = new Dictionary<string, string>(DefaultDictionary, StringComparer.OrdinalIgnoreCase);

            try
            {
                var baseDir = AppDomain.CurrentDomain.BaseDirectory;
                var path = Path.Combine(baseDir, "mascots", "english_readings.json");
                if (!File.Exists(path))
                {
                    Debug.WriteLine($"[EnglishReadingConverter] 辞書ファイルが見つかりません: {path}");
                    return dictionary;
                }

                using var stream = File.OpenRead(path);
                using var doc = JsonDocument.Parse(stream);

                if (doc.RootElement.ValueKind != JsonValueKind.Object)
                {
                    Debug.WriteLine("[EnglishReadingConverter] 辞書ファイルの形式が不正です");
                    return dictionary;
                }

                foreach (var property in doc.RootElement.EnumerateObject())
                {
                    if (property.Value.ValueKind == JsonValueKind.String)
                    {
                        dictionary[property.Name] = property.Value.GetString() ?? string.Empty;
                    }
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[EnglishReadingConverter] 辞書ファイルの読み込みに失敗しました: {ex.Message}");
            }

            return dictionary;
        }

        private static async Task<string?> ConvertWithLlmAsync(string text)
        {
            try
            {
                var serviceName = SystemConfig.Instance.LlmService;
                var service = LlmManager.CreateService(serviceName);
                if (service == null)
                {
                    return null;
                }

                if (!string.IsNullOrWhiteSpace(SystemConfig.Instance.ChatAiEndpoint))
                {
                    service.EndPoint = SystemConfig.Instance.ChatAiEndpoint;
                }

                var systemPrompt = "あなたは英単語の一般的なカタカナ読みを作成するアシスタントです。次の文章内に含まれる英単語のみをカタカナ読みへ変換し、その他の日本語や記号は変更せずにそのまま出力してください。出力は変換後の文章のみとしてください。";

                Debug.WriteLine($"[EnglishReadingConverter] LLMへ英単語変換を依頼します: service={serviceName}");

                var response = await service.SendOneShotMessageAsync(systemPrompt, text);
                if (string.IsNullOrWhiteSpace(response))
                {
                    Debug.WriteLine("[EnglishReadingConverter] LLMの応答が空でした");
                    return null;
                }

                var cleaned = EmotionTagRegex.Replace(response, string.Empty).Trim();
                return string.IsNullOrWhiteSpace(cleaned) ? null : cleaned;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[EnglishReadingConverter] LLMとの接続エラー: {ex.Message}");
                return null;
            }
        }

        private static string ReplaceRemainingEnglishWords(string text)
        {
            return EnglishWordRegex.Replace(text, match => SpellOutEnglishWord(match.Value));
        }

        private static string SpellOutEnglishWord(string word)
        {
            var builder = new StringBuilder();
            foreach (var letter in word)
            {
                var upperLetter = char.ToUpperInvariant(letter);
                if (AlphabetReadings.TryGetValue(upperLetter, out var reading))
                {
                    builder.Append(reading);
                }
                else
                {
                    builder.Append(letter);
                }
            }

            return builder.ToString();
        }
    }
}
