    internal class ComfyWorkflowEdit
    {
        private string WorkflowPath = "";
        private Dictionary<string, JsonElement> WorkflowData = new Dictionary<string, JsonElement>();

        private ComfyWorkflowEdit(string workflowPath, Dictionary<string, JsonElement> workflowData)
        {
            WorkflowPath = workflowPath;
            WorkflowData = workflowData;
        }

        public static async Task<ComfyWorkflowEdit> Load(string workflowPath)
        {
            // ワークフローファイルを読み込む
            var workflowJson = await File.ReadAllTextAsync(workflowPath);

            // JSONをパースする
            var workflow = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(workflowJson);
            if(workflow == null)
            {
                throw new Exception("Failed to parse workflow JSON.");
            }

            return new ComfyWorkflowEdit(workflowPath, workflow);
        }

