using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using System.Diagnostics;
using DesktopAiMascot.mascots;
using DesktopAiMascot.Controls;
using Google.GenAI;

namespace DesktopAiMascot.aiservice.chat
{
    public class GoogleAiStudioChatService : ChatAiServiceBase
    {
        private const string DEFAULT_MODEL = "gemini-2.0-flash-exp";
        private readonly Google.GenAI.Client? _client;
        private readonly Dictionary<string, string> _displayNameToIdMap = new Dictionary<string, string>();
        
        public override string EndPoint { get; set; }

        public GoogleAiStudioChatService()
        {
            var apiKey = LoadApiKey();
            
            if (!string.IsNullOrWhiteSpace(apiKey))
            {
                _client = new Google.GenAI.Client(apiKey: apiKey);
            }
            
            EndPoint = "https://generativelanguage.googleapis.com/v1beta/";
        }

        public override async Task<string[]> GetAvailableModels(bool reload)
        {
            if (_client == null)
            {
                Debug.WriteLine("Google AI Client is not initialized. API key may be missing. Returning default model.");
                return new[] { DEFAULT_MODEL };
            }

            try
            {
                Debug.WriteLine("Fetching available models from Google AI Studio...");
                
                var models = new List<string>();
                
                var pager = await _client.Models.ListAsync();
                
                await foreach (var model in pager)
                {
                    if (model.SupportedActions != null && model.SupportedActions.Contains("generateContent"))
                    {
                        if (!string.IsNullOrEmpty(model.Name))
                        {
                            var cleanId = model.Name.StartsWith("models/") ? model.Name.Substring(7) : model.Name;
                            
                            // ModelDisplayItemを使用して表示名を生成
                            var displayItem = new ModelDisplayItem(cleanId, model.Thinking == true);
                            
                            // マッピングを保存
                            _displayNameToIdMap[displayItem.DisplayName] = cleanId;
                            
                            models.Add(displayItem.DisplayName);
                            Debug.WriteLine($"Found model: {displayItem.DisplayName} (ID: {cleanId})");
                        }
                    }
                }

                if (models.Count == 0)
                {
                    Debug.WriteLine("No models found, returning default model.");
                    return new[] { DEFAULT_MODEL };
                }

                // 表示名でソートして返す
                return models.OrderBy(m => m).ToArray();
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to get available models: {ex.Message}");
                return new[] { DEFAULT_MODEL };
            }
        }

        public override async Task<string?> SendMessageAsync(string message)
        {
            if (_client == null)
            {
                return "Error: Google AI API key is not configured. Please set the API key in settings.";
            }

            try
            {
                var systemPrompt = LoadSystemPrompt() ?? "You are a helpful assistant.";
                var modelName = SystemConfig.Instance.ModelName ?? DEFAULT_MODEL;

                Debug.WriteLine($"[GoogleAiStudio] Original model name from config: {modelName}");
                
                // 表示名からIDに変換
                if (_displayNameToIdMap.TryGetValue(modelName, out var modelId))
                {
                    modelName = modelId;
                    Debug.WriteLine($"[GoogleAiStudio] Converted to model ID: {modelName}");
                }
                else
                {
                    // マッピングが見つからない場合は、装飾を削除してIDを抽出
                    Debug.WriteLine($"[GoogleAiStudio] Model name not found in mapping, cleaning up decorations...");
                    
                    // すべての装飾を削除
                    modelName = modelName
                        .Replace(" [思考]", "")
                        .Replace(" ✨思考モード対応", "")
                        .Replace(" (思考モード対応)", "")
                        .Replace(" [実験版]", "")
                        .Replace(" [最新版]", "")
                        .Replace(" [v1]", "")
                        .Replace(" [v2]", "")
                        .Replace(" Preview", "")
                        .Replace(" [画像生成]", "")
                        .Replace(" [TTS]", "")
                        .Replace(" [埋込]", "")
                        .Trim();
                    
                    // Geminiの表示名を元に戻す
                    if (modelName.StartsWith("Gemini "))
                    {
                        // "Gemini 2.0 Flash" → "gemini-2.0-flash"
                        modelName = modelName
                            .Replace("Gemini ", "gemini-")
                            .Replace(" Flash", "-flash")
                            .Replace(" Pro", "-pro")
                            .Replace(" ", "-")
                            .ToLower();
                    }
                    
                    // Gemmaの表示名を元に戻す
                    if (modelName.StartsWith("Gemma 3n ("))
                    {
                        // "Gemma 3n (E4B)" → "gemma-3n-e4b"
                        var size = modelName.Replace("Gemma 3n (", "").Replace(")", "").ToLower();
                        modelName = $"gemma-3n-{size}";
                    }
                    else if (modelName.StartsWith("Gemma 3 ("))
                    {
                        // "Gemma 3 (1B)" → "gemma-3-1b"
                        var size = modelName.Replace("Gemma 3 (", "").Replace(")", "").ToLower();
                        modelName = $"gemma-3-{size}";
                    }
                    
                    // Nano Bananaの表示名を元に戻す
                    if (modelName.StartsWith("Nano Banana Pro"))
                    {
                        modelName = "nano-banana-pro-preview";
                    }
                    else if (modelName.Contains("Nano Banana"))
                    {
                        modelName = "gemini-2.5-flash-image";
                    }
                    
                    Debug.WriteLine($"[GoogleAiStudio] Cleaned model name: {modelName}");
                }

                Debug.WriteLine($"[GoogleAiStudio] Final model ID to send to API: {modelName}");

                // システムプロンプトとメッセージを結合
                var fullMessage = $"{systemPrompt}\n\n{message}";
                
                // チャット履歴がある場合は考慮する必要があるが、
                // シンプルな実装として現在のメッセージのみを送信
                var response = await _client.Models.GenerateContentAsync(modelName, fullMessage);
                
                if (response?.Candidates != null && response.Candidates.Count > 0)
                {
                    var candidate = response.Candidates[0];
                    if (candidate?.Content?.Parts != null && candidate.Content.Parts.Count > 0)
                    {
                        return candidate.Content.Parts[0].Text;
                    }
                }
                
                return "Error: No response content from Google AI Studio";
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"GoogleAiStudio error: {ex.Message}");
                
                if (ex.Message.Contains("429") || ex.Message.Contains("Rate limit"))
                {
                    return "Error: Rate limit exceeded. Please wait a moment and try again, or try using a different model like 'gemini-2.0-flash-exp'.";
                }
                else if (ex.Message.Contains("400"))
                {
                    return $"Error: Invalid request. The model '{SystemConfig.Instance.ModelName}' may not be available. Try using 'gemini-2.0-flash-exp' instead.";
                }
                else if (ex.Message.Contains("404"))
                {
                    return $"Error: Model not found. The model '{SystemConfig.Instance.ModelName}' may not exist. Try using 'gemini-2.0-flash-exp' instead.";
                }
                
                return $"Error: {ex.Message}";
            }
        }

        public override void ClearConversation()
        {
        }

        private static string? LoadSystemPrompt()
        {
            var model = MascotManager.Instance.CurrentModel;
            var promptText = model?.Prompt;
            return promptText;
        }

        private static string? LoadApiKey()
        {
            try
            {
                // 新しいキー名を優先
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleAiStudioApiKey", out var apiKey))
                {
                    return string.IsNullOrWhiteSpace(apiKey) ? null : apiKey;
                }
                
                // 後方互換性のため、古いキー名もチェック
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleApiKey", out var oldApiKey))
                {
                    return string.IsNullOrWhiteSpace(oldApiKey) ? null : oldApiKey;
                }

                return null;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load API key: {ex.Message}");
                return null;
            }
        }
    }
}
