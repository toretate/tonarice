using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using System.Diagnostics;
using DesktopAiMascot.mascots;
using DesktopAiMascot.Controls;
using OpenAI;
using OpenAI.Chat;
using System.ClientModel;

namespace DesktopAiMascot.aiservice.chat
{
    public class GoogleAiStudioChatService : ChatAiServiceBase
    {
        private const string DEFAULT_MODEL = "gemini-2.0-flash-exp";
        private const string GOOGLE_API_ENDPOINT = "https://generativelanguage.googleapis.com/v1beta/openai/";
        
        public override string EndPoint { get; set; }

        public GoogleAiStudioChatService()
        {
            EndPoint = GOOGLE_API_ENDPOINT;
        }

        public override async Task<string[]> GetAvailableModels(bool reload)
        {
            var apiKey = LoadApiKey();
            
            if (string.IsNullOrWhiteSpace(apiKey))
            {
                Debug.WriteLine("Google AI API key is not configured. Returning default model.");
                return new[] { DEFAULT_MODEL };
            }

            try
            {
                Debug.WriteLine("Fetching available models from Google AI Studio...");
                
                var client = new OpenAIClient(new ApiKeyCredential(apiKey), new OpenAIClientOptions()
                {
                    Endpoint = new Uri(EndPoint),
                });

                var models = new List<string>();
                
                await foreach (var model in client.GetModelsAsync())
                {
                    var modelId = model.Value.Id;
                    if (!string.IsNullOrEmpty(modelId))
                    {
                        models.Add(modelId);
                        Debug.WriteLine($"Found model: {modelId}");
                    }
                }

                if (models.Count == 0)
                {
                    Debug.WriteLine("No models found, returning default model.");
                    return new[] { DEFAULT_MODEL };
                }

                return models.ToArray();
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to get available models: {ex.Message}");
                return new[] { DEFAULT_MODEL };
            }
        }

        public override async Task<string?> SendMessageAsync(string message)
        {
            var apiKey = LoadApiKey();
            
            if (string.IsNullOrWhiteSpace(apiKey))
            {
                return "Error: Google AI API key is not configured. Please set the API key in settings.";
            }

            try
            {
                var systemPrompt = LoadSystemPrompt() ?? "You are a helpful assistant.";
                var modelName = SystemConfig.Instance.ModelName ?? DEFAULT_MODEL;

                Debug.WriteLine($"GoogleAiStudio request with model: {modelName}");

                var client = new OpenAIClient(new ApiKeyCredential(apiKey), new OpenAIClientOptions()
                {
                    Endpoint = new Uri(EndPoint),
                });

                var chatClient = client.GetChatClient(modelName);

                var messages = new List<OpenAI.Chat.ChatMessage>
                {
                    new SystemChatMessage(systemPrompt),
                };

                var chatHistory = ChatHistory.GetMessages();
                foreach (var m in chatHistory)
                {
                    if (string.Equals(m.Sender, "Assistant", StringComparison.OrdinalIgnoreCase))
                    {
                        messages.Add(new AssistantChatMessage(m.Text));
                    }
                    else
                    {
                        messages.Add(new UserChatMessage(m.Text));
                    }
                }

                var response = await chatClient.CompleteChatAsync(messages);
                var text = response.Value.Content[0].Text;
                return text;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"GoogleAiStudio error: {ex.Message}");
                return $"Error: {ex.Message}";
            }
        }

        public override void ClearConversation()
        {
        }

        private static string? LoadSystemPrompt()
        {
            var model = MascotManager.Instance.CurrentModel;
            var promptText = model?.Prompt;
            return promptText;
        }

        private static string? LoadApiKey()
        {
            try
            {
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleApiKey", out var apiKey))
                {
                    return string.IsNullOrWhiteSpace(apiKey) ? null : apiKey;
                }

                return null;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load API key: {ex.Message}");
                return null;
            }
        }
    }
}
