using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using System.Diagnostics;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using DesktopAiMascot.mascots;
using DesktopAiMascot.Controls;

namespace DesktopAiMascot.aiservice.chat
{
    public class GoogleCloudChatService : ChatAiServiceBase
    {
        private const string DEFAULT_MODEL = "gemini-2.0-flash-exp";
        private const string DEFAULT_REGION = "us-central1";
        private static readonly HttpClient httpClient = new HttpClient() { Timeout = TimeSpan.FromSeconds(60) };
        
        public override string EndPoint { get; set; }

        public GoogleCloudChatService()
        {
            EndPoint = $"https://{DEFAULT_REGION}-aiplatform.googleapis.com/v1/";
        }

        public override async Task<string[]> GetAvailableModels(bool reload)
        {
            var apiKey = LoadApiKey();
            
            if (string.IsNullOrWhiteSpace(apiKey))
            {
                Debug.WriteLine("Google Cloud API key is not configured. Returning default model.");
                return new[] { DEFAULT_MODEL };
            }

            // Vertex AI では動的なモデル一覧取得が制限されているため、固定リストを返す
            return new[]
            {
                "gemini-2.0-flash-exp",
                "gemini-1.5-flash",
                "gemini-1.5-pro",
                "gemini-pro"
            };
        }

        public override async Task<string?> SendMessageAsync(string message)
        {
            var apiKey = LoadApiKey();
            var projectId = LoadProjectId();
            
            if (string.IsNullOrWhiteSpace(apiKey))
            {
                return "Error: Google Cloud API key is not configured. Please set the API key in settings.";
            }
            
            if (string.IsNullOrWhiteSpace(projectId))
            {
                return "Error: Google Cloud Project ID is not configured. Please set it in API Key settings.";
            }

            try
            {
                var systemPrompt = LoadSystemPrompt() ?? "You are a helpful assistant.";
                var modelName = SystemConfig.Instance.ModelName ?? DEFAULT_MODEL;
                var region = LoadRegion() ?? DEFAULT_REGION;

                Debug.WriteLine($"GoogleCloud request with model: {modelName}");
                Debug.WriteLine($"Using project: {projectId}, region: {region}");

                var url = $"https://{region}-aiplatform.googleapis.com/v1/projects/{projectId}/locations/{region}/publishers/google/models/{modelName}:generateContent";

                var contents = new List<object>();
                
                // システムプロンプトを最初のメッセージとして追加
                contents.Add(new
                {
                    role = "user",
                    parts = new[] { new { text = systemPrompt } }
                });

                // チャット履歴を追加
                var chatHistory = ChatHistory.GetMessages();
                foreach (var m in chatHistory)
                {
                    var role = string.Equals(m.Sender, "Assistant", StringComparison.OrdinalIgnoreCase) ? "model" : "user";
                    contents.Add(new
                    {
                        role = role,
                        parts = new[] { new { text = m.Text } }
                    });
                }

                var requestBody = new
                {
                    contents = contents
                };

                var json = JsonSerializer.Serialize(requestBody);
                using var content = new StringContent(json, Encoding.UTF8, "application/json");

                httpClient.DefaultRequestHeaders.Remove("x-goog-api-key");
                httpClient.DefaultRequestHeaders.Add("x-goog-api-key", apiKey);

                Debug.WriteLine($"Sending request to: {url}");

                var response = await httpClient.PostAsync(url, content);
                var responseBody = await response.Content.ReadAsStringAsync();

                if (!response.IsSuccessStatusCode)
                {
                    Debug.WriteLine($"Google Cloud API error: {response.StatusCode} {responseBody}");
                    return $"Error: API returned {response.StatusCode}. {responseBody}";
                }

                using var doc = JsonDocument.Parse(responseBody);
                var root = doc.RootElement;

                if (root.TryGetProperty("candidates", out var candidates) && candidates.GetArrayLength() > 0)
                {
                    var candidate = candidates[0];
                    if (candidate.TryGetProperty("content", out var contentElem) &&
                        contentElem.TryGetProperty("parts", out var parts) &&
                        parts.GetArrayLength() > 0)
                    {
                        var part = parts[0];
                        if (part.TryGetProperty("text", out var textElem))
                        {
                            return textElem.GetString();
                        }
                    }
                }

                return "Error: No response content from Google Cloud";
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"GoogleCloud error: {ex.Message}");
                Debug.WriteLine($"Stack trace: {ex.StackTrace}");
                return $"Error: {ex.Message}";
            }
        }

        public override void ClearConversation()
        {
        }

        private static string? LoadSystemPrompt()
        {
            var model = MascotManager.Instance.CurrentModel;
            var promptText = model?.Prompt;
            return promptText;
        }

        private static string? LoadApiKey()
        {
            try
            {
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleApiKey", out var apiKey))
                {
                    return string.IsNullOrWhiteSpace(apiKey) ? null : apiKey;
                }

                return null;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load API key: {ex.Message}");
                return null;
            }
        }

        private static string? LoadProjectId()
        {
            try
            {
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleProjectId", out var projectId))
                {
                    return string.IsNullOrWhiteSpace(projectId) ? null : projectId;
                }

                return null;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load Project ID: {ex.Message}");
                return null;
            }
        }

        private static string? LoadRegion()
        {
            try
            {
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleRegion", out var region))
                {
                    return string.IsNullOrWhiteSpace(region) ? null : region;
                }

                return DEFAULT_REGION;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load Region: {ex.Message}");
                return DEFAULT_REGION;
            }
        }
    }
}
