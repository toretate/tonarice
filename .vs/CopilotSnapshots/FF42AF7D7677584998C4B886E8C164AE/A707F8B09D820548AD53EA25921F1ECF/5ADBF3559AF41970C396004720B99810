<UserControl x:Class="DesktopAiMascot.views.ApiKeyPropertyPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:DesktopAiMascot.views"
         mc:Ignorable="d" 
         d:DesignHeight="500" d:DesignWidth="480"
         Background="White">
    <StackPanel>
        <GroupBox Header="Google API Configuration" Padding="10" Background="White" Margin="0,0,0,10">
            <StackPanel>
                <Label Content="Google API Key" 
                       FontWeight="Bold"
                       Margin="0,0,0,0"
                       Padding="0"/>
                <TextBox x:Name="apiKeyTextBox" 
                         Height="25"
                         Margin="0,0,0,15"
                         AllowDrop="True"
                         Tag="Google API KEY"
                         VerticalContentAlignment="Center"/>

                <Label Content="Google Cloud Project ID (for Vertex AI)" 
                       FontWeight="Bold"
                       Margin="0,0,0,0"
                       Padding="0"/>
                <TextBox x:Name="projectIdTextBox" 
                         Height="25"
                         Margin="0,0,0,15"
                         Tag="Google Project ID"
                         VerticalContentAlignment="Center"/>

                <Label Content="Region (for Vertex AI)" 
                       FontWeight="Bold"
                       Margin="0,0,0,0"
                       Padding="0"/>
                <TextBox x:Name="regionTextBox" 
                         Height="25"
                         Margin="0,0,0,10"
                         Tag="Region (e.g. us-central1)"
                         VerticalContentAlignment="Center"
                         Text="us-central1"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="saveApiKeyButton" 
                            Content="Save" 
                            Width="75"
                            Height="25"
                            Margin="0,0,10,0"
                            Click="SaveApiKeyButton_Click"/>
                    <Button x:Name="clearApiKeyButton" 
                            Content="Clear" 
                            Width="75"
                            Height="25"
                            Click="ClearApiKeyButton_Click"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
