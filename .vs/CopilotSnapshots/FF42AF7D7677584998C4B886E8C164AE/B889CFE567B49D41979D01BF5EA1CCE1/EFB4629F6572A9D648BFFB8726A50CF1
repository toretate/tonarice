using System;
using System.Collections.Generic;
using System.Linq;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;
using System.Diagnostics;
using DesktopAiMascot.mascots;

namespace DesktopAiMascot.aiservice.chat
{
    public class GoogleAiStudioChatService : ChatAiServiceBase
    {
        private static readonly HttpClient httpClient = new HttpClient() { Timeout = TimeSpan.FromSeconds(60) };
        private readonly string? _apiKey;
        private const string DEFAULT_MODEL = "gemini-2.0-flash-exp";
        
        public override string EndPoint { get; set; }

        public GoogleAiStudioChatService()
        {
            _apiKey = LoadApiKey();
            EndPoint = "https://generativelanguage.googleapis.com/v1beta/models/";
        }

        public override async Task<string?> SendMessageAsync(string message)
        {
            if (string.IsNullOrWhiteSpace(_apiKey))
            {
                return "Error: Google AI API key is not configured. Please set the API key in settings.";
            }

            try
            {
                var systemPrompt = LoadSystemPrompt() ?? "You are a helpful assistant.";
                var modelName = SystemConfig.Instance.ModelName ?? DEFAULT_MODEL;

                var contents = new[]
                {
                    new
                    {
                        role = "user",
                        parts = new[]
                        {
                            new { text = $"{systemPrompt}\n\n{message}" }
                        }
                    }
                };

                var requestObj = new { contents = contents };
                var json = JsonSerializer.Serialize(requestObj);

                using var content = new StringContent(json, Encoding.UTF8, "application/json");

                var endpoint = $"{EndPoint.TrimEnd('/')}/{modelName}:generateContent?key={_apiKey}";

                Debug.WriteLine($"GoogleAiStudio request to: {endpoint.Replace(_apiKey, "***")}");

                var response = await httpClient.PostAsync(endpoint, content).ConfigureAwait(false);
                var responseBody = await response.Content.ReadAsStringAsync().ConfigureAwait(false);

                if (!response.IsSuccessStatusCode)
                {
                    Debug.WriteLine($"Google AI Studio API error: {response.StatusCode} {responseBody}");
                    return $"Error: API returned {response.StatusCode}";
                }

                using var doc = JsonDocument.Parse(responseBody);
                var root = doc.RootElement;

                if (root.TryGetProperty("candidates", out var candidates) && candidates.GetArrayLength() > 0)
                {
                    var candidate = candidates[0];
                    if (candidate.TryGetProperty("content", out var contentElem) &&
                        contentElem.TryGetProperty("parts", out var parts) &&
                        parts.GetArrayLength() > 0)
                    {
                        var part = parts[0];
                        if (part.TryGetProperty("text", out var textElem))
                        {
                            return textElem.GetString();
                        }
                    }
                }

                return "Error: Unexpected response format from Google AI Studio";
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"GoogleAiStudio error: {ex.Message}");
                return $"Error: {ex.Message}";
            }
        }

        public override void ClearConversation()
        {
        }

        private static string? LoadSystemPrompt()
        {
            var model = MascotManager.Instance.CurrentModel;
            var promptText = model?.Prompt;
            return promptText;
        }

        private static string? LoadApiKey()
        {
            try
            {
                if (SystemConfig.Instance.ApiKeys.TryGetValue("GoogleApiKey", out var apiKey))
                {
                    return string.IsNullOrWhiteSpace(apiKey) ? null : apiKey;
                }

                return null;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Failed to load API key: {ex.Message}");
                return null;
            }
        }
    }
}
