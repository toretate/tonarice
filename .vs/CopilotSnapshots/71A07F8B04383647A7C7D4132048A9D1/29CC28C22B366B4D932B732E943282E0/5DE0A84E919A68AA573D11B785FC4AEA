using System;
using System.Windows.Controls;

namespace DesktopAiMascot.views
{
    public partial class MascotPropertyPage : System.Windows.Controls.UserControl
    {
        // マスコット変更時のイベント
        public event EventHandler<EventArgs>? MascotChanged;

        public MascotPropertyPage()
        {
            InitializeComponent();
        }

        protected virtual void OnMascotChanged(EventArgs e)
        {
            MascotChanged?.Invoke(this, e);
        }
    }
}
