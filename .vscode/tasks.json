{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/DesktopAiMascot.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile"
		},
		{
			// Godot プロジェクトをデバッグなしで起動するタスク
			"label": "Godot を起動-headless",
			"type": "shell",
			"command": "C:\\Free\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64.exe",
			"args": [
				"--path",
				"${workspaceFolder}",
				"--headless"
			],
			"problemMatcher": []
		},
		{
			// Godot エディタを開くタスク
			"label": "Godot エディタを開く",
			"type": "shell",
			"command": "C:\\Free\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64\\Godot_v4.6.1-stable_mono_win64.exe",
			"args": [
				"--path",
				"${workspaceFolder}",
				"-e"
			],
			"problemMatcher": []
		},
		{
			"label": "build",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/DesktopAiMascot.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"group": "build"
		}
	]
}