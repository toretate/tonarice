        "js-yaml": "^4.2.0",
        "pinia": "^3.0.4",
        "primeflex": "^4.0.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.0.0",
        "vue": "^3.4.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.7",
        "autoprefixer": "^10.5.0",
        "canvas": "^3.2.3",
        "electron": "^42.4.0",
        "happy-dom": "^20.10.2",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.4.0",
        "vite": "^8.0.16",
        "vite-plugin-electron": "^0.28.0",
